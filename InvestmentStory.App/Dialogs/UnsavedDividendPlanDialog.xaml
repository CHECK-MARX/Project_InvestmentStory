<Window x:Class="InvestmentStory.App.Dialogs.UnsavedDividendPlanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="未保存の購入計画"
        Width="520" Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Border Margin="18" Padding="20" Style="{StaticResource MetricCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="未保存の変更があります" FontSize="21" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Margin="0,12,0,18" TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="購入計画を保存してからアプリを終了しますか？" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="保存して終了" Width="125" Height="38" Style="{StaticResource SuccessButtonStyle}" Click="SaveAndExit_Click" />
                <Button Content="保存せず終了" Width="125" Height="38" Style="{StaticResource DangerButtonStyle}" Click="ExitWithoutSaving_Click" />
                <Button Content="キャンセル" Width="100" Height="38" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
