<Window x:Class="InvestmentStory.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:InvestmentStory.App.Views"
        xmlns:vm="clr-namespace:InvestmentStory.App.ViewModels"
        mc:Ignorable="d"
        Title="Investment Story" Height="820" Width="1280" MinHeight="720" MinWidth="1100"
        Background="#F6F7F9" FontFamily="Yu Gothic UI">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockListViewModel}">
            <views:StockListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimpleRegistrationViewModel}">
            <views:SimpleRegistrationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockEditorViewModel}">
            <views:StockEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockDetailViewModel}">
            <views:StockDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DividendsViewModel}">
            <views:DividendsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PassiveIncomeViewModel}">
            <views:PassiveIncomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimulationViewModel}">
            <views:SimulationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CsvImportViewModel}">
            <views:CsvImportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BrokerIntegrationViewModel}">
            <views:BrokerIntegrationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DCE2EA" BorderThickness="0,0,1,0">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Investment Story" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,20" />
                    <Button Content="ダッシュボード" Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="かんたん登録" Command="{Binding ShowSimpleRegistrationCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="銘柄一覧" Command="{Binding ShowStockListCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="詳細登録・編集" Command="{Binding ShowStockEditorCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="銘柄詳細" Command="{Binding ShowStockDetailCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="配当実績" Command="{Binding ShowDividendsCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="不労所得" Command="{Binding ShowPassiveIncomeCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="未来シミュレーション" Command="{Binding ShowSimulationCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="CSV取込" Command="{Binding ShowCsvImportCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="取込・統合設定" Command="{Binding ShowBrokerIntegrationCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="設定" Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButtonStyle}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <TextBlock Text="DB" Foreground="#7B8494" FontSize="12" />
                    <TextBlock Text="{Binding DatabasePath}" TextWrapping="Wrap" Foreground="#7B8494" FontSize="11" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" BorderBrush="#DCE2EA" BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <Button DockPanel.Dock="Right" Content="再読込" Command="{Binding RefreshCommand}"
                            Style="{StaticResource ActionButtonStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentTitle}" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#1F2937" />
                </DockPanel>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
