<Window x:Class="InvestmentStory.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:InvestmentStory.App.Views"
        xmlns:vm="clr-namespace:InvestmentStory.App.ViewModels"
        xmlns:infra="clr-namespace:InvestmentStory.App.Infrastructure"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Yu Gothic UI">
    <Window.Resources>
        <infra:BindingProxy x:Key="VmProxy" Data="{Binding}" />
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockListViewModel}">
            <views:StockListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimpleRegistrationViewModel}">
            <views:SimpleRegistrationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockEditorViewModel}">
            <views:StockEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockDetailViewModel}">
            <views:StockDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DividendsViewModel}">
            <views:DividendsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PassiveIncomeViewModel}">
            <views:PassiveIncomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimulationViewModel}">
            <views:SimulationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CsvImportViewModel}">
            <views:CsvImportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BrokerIntegrationViewModel}">
            <views:BrokerIntegrationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding Data.SidebarWidth, Source={StaticResource VmProxy}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Content="{Binding SidebarToggleText}"
                                Command="{Binding ToggleSidebarCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="38"
                                Padding="0"
                                ToolTip="サイドバーを折りたたむ" />
                        <TextBlock Text="Investment Story"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SidebarTextVisibility}" />
                    </DockPanel>

                    <TextBlock Text="ホーム" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="ダッシュボード">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="H" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="ダッシュボード" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="ポートフォリオ" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowStockListCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="銘柄一覧">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="P" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="銘柄一覧" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowStockDetailCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="銘柄分析">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="A" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="銘柄分析" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="インカム" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowDividendsCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="配当実績・予定">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="D" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="配当実績・予定" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowPassiveIncomeCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="不労所得">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="I" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="不労所得" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="分析" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowSimulationCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="未来シミュレーション">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="S" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="未来シミュレーション" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="データ" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowCsvImportCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="CSV取込">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="C" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="CSV取込" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowBrokerIntegrationCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="取込・統合設定">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="M" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="取込・統合設定" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="設定" Style="{StaticResource NavCategoryTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                    <Button Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="設定">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="G" Style="{StaticResource NavIconTextStyle}" />
                            <TextBlock Text="設定" Style="{StaticResource NavLabelTextStyle}" Visibility="{Binding SidebarTextVisibility}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Visibility="{Binding SidebarFooterVisibility}">
                    <TextBlock Text="DB" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <TextBlock Text="{Binding DatabasePath}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="11" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="サンプル初期化"
                                Command="{Binding ResetSampleDataCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding SampleModeVisibility}" />
                        <Button Content="{Binding SampleModeToggleText}"
                                Command="{Binding ToggleSampleModeCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="再読込"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ActionButtonStyle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Background="{DynamicResource WarningBrush}"
                            CornerRadius="8"
                            Padding="10,4"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding SampleModeVisibility}">
                        <StackPanel>
                            <TextBlock Text="{Binding DataModeBadge}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource WindowBackgroundBrush}" />
                            <TextBlock Text="{Binding DataModeDescription}"
                                       FontSize="10"
                                       Foreground="{DynamicResource WindowBackgroundBrush}" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding CurrentTitle}"
                               FontSize="26"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </DockPanel>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
