<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#F4F7FB</Color>
    <Color x:Key="SidebarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SurfaceBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ElevatedSurfaceColor">#F8FAFC</Color>
    <Color x:Key="BorderColorValue">#D8E0EA</Color>
    <Color x:Key="PrimaryTextColor">#111827</Color>
    <Color x:Key="SecondaryTextColor">#475569</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="AccentBlueColor">#0284C7</Color>
    <Color x:Key="AccentBlueDarkColor">#0369A1</Color>
    <Color x:Key="ProfitGreenColor">#15803D</Color>
    <Color x:Key="LossRedColor">#DC2626</Color>
    <Color x:Key="WarningOrangeColor">#D97706</Color>
    <Color x:Key="DividendPurpleColor">#7C3AED</Color>
    <Color x:Key="NeutralGrayColor">#64748B</Color>
    <Color x:Key="RowBackground1Color">#FFFFFF</Color>
    <Color x:Key="RowBackground2Color">#F5F8FC</Color>
    <Color x:Key="RowHoverBackgroundColor">#EAF3FF</Color>
    <Color x:Key="SelectedRowBackgroundColor">#D7ECFF</Color>
    <Color x:Key="HeaderBackgroundColor">#E7EEF7</Color>
    <Color x:Key="PrimaryButtonGlowColor">#550284C7</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{StaticResource SurfaceBackgroundColor}" />
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurfaceColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColorValue}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="{StaticResource AccentBlueDarkColor}" />
    <SolidColorBrush x:Key="ProfitBrush" Color="{StaticResource ProfitGreenColor}" />
    <SolidColorBrush x:Key="LossBrush" Color="{StaticResource LossRedColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningOrangeColor}" />
    <SolidColorBrush x:Key="DividendBrush" Color="{StaticResource DividendPurpleColor}" />
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralGrayColor}" />
    <SolidColorBrush x:Key="RowBackground1Brush" Color="{StaticResource RowBackground1Color}" />
    <SolidColorBrush x:Key="RowBackground2Brush" Color="{StaticResource RowBackground2Color}" />
    <SolidColorBrush x:Key="RowHoverBackgroundBrush" Color="{StaticResource RowHoverBackgroundColor}" />
    <SolidColorBrush x:Key="SelectedRowBackgroundBrush" Color="{StaticResource SelectedRowBackgroundColor}" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryButtonGlowBrush" Color="{StaticResource PrimaryButtonGlowColor}" />
</ResourceDictionary>
