<UserControl x:Class="InvestmentStory.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <DockPanel Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="投資ダッシュボード" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding MarketDataStatus}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" />
                    <TextBlock Text="{Binding DataUpdateStatus}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <UniformGrid Columns="4">
                <Border Style="{StaticResource HeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource AccentBlueBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="総資産" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{Binding TotalCurrentMarketValue}" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock Text="現在評価額合計" Style="{StaticResource SubtleTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource ProfitBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="含み損益" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{Binding TotalUnrealizedGain}" Style="{StaticResource MetricValueTextStyle}" Foreground="{DynamicResource ProfitBrush}" />
                            <TextBlock Text="{Binding TotalUnrealizedGainRate}" Style="{StaticResource SubtleTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource DividendBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="今年の配当実績" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{Binding ThisYearPassiveIncome}" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock Text="税引後入金ベース" Style="{StaticResource SubtleTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource WarningBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="年間目標達成率" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{Binding AnnualGoalAchievementRate}" Style="{StaticResource MetricValueTextStyle}" Foreground="{DynamicResource WarningBrush}" />
                            <ProgressBar Value="{Binding AnnualGoalProgressValue, Mode=OneWay}" Maximum="100" Height="7" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <TextBlock Text="NISA口座サマリー" Style="{StaticResource SectionTitleStyle}" Margin="0,6,0,8" />
            <ItemsControl ItemsSource="{Binding NisaSummaries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource DividendBrush}" CornerRadius="3" />
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding PositionCountText}"
                                                   Style="{StaticResource SubtleTextStyle}"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource SubtleTextStyle}" Margin="0,2,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="評価額" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding MarketValueJpy}" FontSize="22" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="取得額" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding PurchaseAmountJpy}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="評価損益" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding GainLossJpy}" FontSize="20" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPositiveGain}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource ProfitBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasNegativeGain}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource LossBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="評価損益率" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding GainLossRate}" FontSize="18" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPositiveGain}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource ProfitBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasNegativeGain}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource LossBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <UniformGrid Columns="2">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間配当見込み" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualPassiveIncomeForecast}" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                        <TextBlock Text="月平均" Style="{StaticResource LabelTextStyle}" Margin="0,12,0,4" />
                        <TextBlock Text="{Binding MonthlyAveragePassiveIncomeForecast}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="目標まで" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualGoalGap}" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock Text="月10万円まで" Style="{StaticResource LabelTextStyle}" Margin="0,12,0,4" />
                        <TextBlock Text="{Binding Monthly100kGap}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="配当込み総合リターン" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TotalReturn}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                        <TextBlock Text="{Binding TotalReturnRate}" Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="累計受取配当" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CumulativeDividend}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                        <TextBlock Text="Actualのみ / Replaced除外" Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="前日比 / 前月比" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TotalAssetDayChange}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TotalAssetMonthChange}" Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="上位5銘柄集中率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding Top5ConcentrationRate}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock Text="{Binding CapitalRecoveryRate, StringFormat=元本回収率 {0}}" Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="現在値を記録" Command="{Binding RecordSnapshotCommand}" Style="{StaticResource ActionButtonStyle}" />
                            <ComboBox DockPanel.Dock="Right"
                                      ItemsSource="{Binding HistoryPeriods}"
                                      SelectedItem="{Binding SelectedHistoryPeriod, Mode=TwoWay}"
                                      Width="120"
                                      Margin="0,0,10,0" />
                            <TextBlock Text="資産推移" Style="{StaticResource SectionTitleStyle}" />
                        </DockPanel>
                        <Border MinHeight="220" Background="{DynamicResource ElevatedSurfaceBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                            <StackPanel>
                                <TextBlock Text="同日分は最新値で更新します。資産履歴は今後の起動時またはAPI/CSV更新時に蓄積されます。"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />
                                <TextBlock Text="{Binding PortfolioHistoryMessage}"
                                           Foreground="{DynamicResource WarningBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />
                                <ItemsControl ItemsSource="{Binding PortfolioHistoryRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7" ToolTip="{Binding ToolTip}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Date}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <StackPanel Grid.Column="1">
                                                    <Grid Height="9" Background="{DynamicResource SurfaceBackgroundBrush}" Margin="0,0,0,3">
                                                        <Border Width="{Binding TotalBarWidth}" Background="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Left" CornerRadius="5" />
                                                    </Grid>
                                                    <Grid Height="7" Background="{DynamicResource SurfaceBackgroundBrush}" Margin="0,0,0,3">
                                                        <Border Width="{Binding CostBarWidth}" Background="{DynamicResource NeutralBrush}" HorizontalAlignment="Left" CornerRadius="4" />
                                                    </Grid>
                                                    <Grid Height="7" Background="{DynamicResource SurfaceBackgroundBrush}">
                                                        <Border Width="{Binding GainBarWidth}" Background="{DynamicResource ProfitBrush}" HorizontalAlignment="Left" CornerRadius="4" />
                                                    </Grid>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TotalMarketValue}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <ComboBox DockPanel.Dock="Right"
                                      ItemsSource="{Binding CompositionModes}"
                                      SelectedItem="{Binding SelectedCompositionMode, Mode=TwoWay}"
                                      Width="130" />
                            <TextBlock Text="資産構成" Style="{StaticResource SectionTitleStyle}" />
                        </DockPanel>
                        <Border MinHeight="220" Background="{DynamicResource ElevatedSurfaceBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding CompositionBars}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7" ToolTip="{Binding ToolTip}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid Grid.Column="1" Height="16" Background="{DynamicResource SurfaceBackgroundBrush}" VerticalAlignment="Center">
                                                    <Border Width="{Binding BarWidth}" Background="{DynamicResource DividendBrush}" HorizontalAlignment="Left" CornerRadius="8" />
                                                </Grid>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AmountJpy}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="為替感応度" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="USD/JPYが変動した場合の総資産への影響です。外貨建て資産のみを対象に概算します。"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding FxSensitivityRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6" ToolTip="{Binding ToolTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding RateDelta}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding UsdJpyRate}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <Grid Grid.Column="2" Height="14" Background="{DynamicResource ElevatedSurfaceBrush}" VerticalAlignment="Center">
                                        <Border Width="{Binding BarWidth}" Background="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Left" CornerRadius="7" />
                                    </Grid>
                                    <TextBlock Grid.Column="3" Text="{Binding ChangeFromCurrent}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="{Binding TotalMarketValue}" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
