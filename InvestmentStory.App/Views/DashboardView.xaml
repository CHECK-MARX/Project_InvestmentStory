<UserControl x:Class="InvestmentStory.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="全体サマリー" Style="{StaticResource SectionTitleStyle}" />
            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在評価額合計" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TotalCurrentMarketValue}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="含み益合計" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TotalUnrealizedGain}" FontSize="24" FontWeight="SemiBold" Foreground="#1C7C54" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="含み益率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TotalUnrealizedGainRate}" FontSize="24" FontWeight="SemiBold" Foreground="#1C7C54" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="外貨建て資産合計USD" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ForeignAssetTotalUsd}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="外貨建て資産の円換算額" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ForeignAssetTotalJpy}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="為替込み含み益合計" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding FxIncludedUnrealizedGain}" FontSize="24" FontWeight="SemiBold" Foreground="#1C7C54" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在のUSD/JPY" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentUsdJpy}" FontSize="24" FontWeight="SemiBold" Foreground="#2F5B8C" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="為替更新日時" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ExchangeRateAcquiredAt}" FontSize="19" FontWeight="SemiBold" Foreground="#1F2937" />
                        <TextBlock Text="{Binding ExchangeRateSource}" FontSize="12" Foreground="#566070" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="今年の不労所得実績" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThisYearPassiveIncome}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間不労所得見込み（概算）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualPassiveIncomeForecast}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月平均不労所得見込み（概算）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MonthlyAveragePassiveIncomeForecast}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="1日あたり不労所得" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding DailyPassiveIncomeForecast}" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間目標達成率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualGoalAchievementRate}" FontSize="24" FontWeight="SemiBold" Foreground="#2F5B8C" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間目標まであといくら" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualGoalGap}" FontSize="24" FontWeight="SemiBold" Foreground="#A43F3F" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月10万円まであといくら" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding Monthly100kGap}" FontSize="24" FontWeight="SemiBold" Foreground="#A43F3F" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
