<UserControl x:Class="InvestmentStory.App.Views.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,18,0">
            <StackPanel>
                <TextBlock Text="未来シミュレーション" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="現在の年間不労所得" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding CurrentAnnualPassiveIncome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                <TextBlock Text="毎月追加投資額" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding MonthlyAdditionalInvestment, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                <TextBlock Text="想定配当利回り" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding AssumedDividendYieldRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                <TextBlock Text="年間増配率" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding AnnualDividendGrowthRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                <TextBlock Text="目標年間不労所得" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding TargetAnnualPassiveIncome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                <Button Content="計算" Command="{Binding RunCommand}" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left" Margin="0,8,0,16" />
                <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap" FontSize="16" FontWeight="SemiBold" Foreground="#2F5B8C" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="0">
            <StackPanel>
                <TextBlock Text="今後10年分の年間不労所得見込み" Style="{StaticResource SectionTitleStyle}" />
                <DataGrid ItemsSource="{Binding Projections}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="年" Binding="{Binding Year}" Width="90" />
                        <DataGridTextColumn Header="経過年数" Binding="{Binding YearsFromNow}" Width="100" />
                        <DataGridTextColumn Header="年間不労所得見込み" Binding="{Binding AnnualPassiveIncome}" Width="180" />
                        <DataGridTextColumn Header="前年差" Binding="{Binding YearOverYearIncrease}" Width="140" />
                        <DataGridTextColumn Header="目標達成率" Binding="{Binding TargetAchievementRate}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
