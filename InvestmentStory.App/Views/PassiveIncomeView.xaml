<UserControl x:Class="InvestmentStory.App.Views.PassiveIncomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="不労所得サマリー" Style="{StaticResource SectionTitleStyle}" />
            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="今月の不労所得" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThisMonthPassiveIncome}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="今年の不労所得" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThisYearPassiveIncome}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="今年の予定配当（概算）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThisYearPlannedIncome}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="今年の実績＋予定" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThisYearForecastIncludingPlanned}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間不労所得見込み（概算）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualPassiveIncomeForecast}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月平均不労所得見込み（概算）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MonthlyAveragePassiveIncome}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="1日あたり不労所得" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding DailyPassiveIncome}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間目標達成率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualGoalAchievementRate}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月間目標達成率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MonthlyGoalAchievementRate}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間目標まであといくら" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualGoalGap}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="外国税（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ForeignTaxActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="国内税（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding DomesticTaxActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="NISA配当（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding NisaDividendActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="課税配当（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding TaxableDividendActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="国内株配当（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding DomesticStockDividendActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="外国株配当（今年実績）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ForeignStockDividendActual}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月10万円まであといくら" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding GapToMonthly100k}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月別配当グラフ" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding MonthlyBars}" Height="260" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <Grid Grid.Column="1" Height="16" Background="{DynamicResource ElevatedSurfaceBrush}" VerticalAlignment="Center">
                                            <Border Width="{Binding BarWidth}" Background="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Left" />
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="{Binding AmountJpy}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年別配当グラフ" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding YearlyBars}" Height="260" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <Grid Grid.Column="1" Height="20" Background="{DynamicResource ElevatedSurfaceBrush}" VerticalAlignment="Center">
                                            <Border Width="{Binding BarWidth}" Background="{DynamicResource ProfitBrush}" HorizontalAlignment="Left" />
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="{Binding AmountJpy}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="銘柄別配当ランキング" Style="{StaticResource SectionTitleStyle}" />
                        <DataGrid ItemsSource="{Binding Ranking}" Height="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="銘柄" Binding="{Binding Label}" Width="*" />
                                <DataGridTextColumn Header="配当合計" Binding="{Binding AmountJpy}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="目標情報" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding GoalMessage}" Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="対象年" Style="{StaticResource LabelTextStyle}" />
                        <TextBox Text="{Binding TargetYear, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBlock Text="年間不労所得目標" Style="{StaticResource LabelTextStyle}" />
                        <TextBox Text="{Binding AnnualPassiveIncomeGoal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBlock Text="月間不労所得目標" Style="{StaticResource LabelTextStyle}" />
                        <TextBox Text="{Binding MonthlyPassiveIncomeGoal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBlock Text="総資産目標" Style="{StaticResource LabelTextStyle}" />
                        <TextBox Text="{Binding TotalAssetGoal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        <Button Content="目標を保存" Command="{Binding SaveGoalCommand}" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
