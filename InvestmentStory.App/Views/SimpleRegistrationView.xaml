<UserControl x:Class="InvestmentStory.App.Views.SimpleRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="かんたん登録" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="まずは最低限の情報だけ入力してください。購入株数、購入単価、現在保有株数、現在株価、為替レートを入力すると、含み益や配当利回りを自動計算できます。米国株・日本株はWeb/APIから会社名、株価、配当情報を取得できます。"
                       TextWrapping="Wrap" Foreground="#566070" FontSize="14" Margin="0,0,0,16" />

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Web/APIから自動補完" Command="{Binding AutoFillCommand}" Style="{StaticResource ActionButtonStyle}" />
                            <Button Content="計算プレビュー" Command="{Binding PreviewCommand}" Style="{StaticResource ActionButtonStyle}" />
                            <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" />
                            <Button Content="クリア" Command="{Binding ResetCommand}" Style="{StaticResource ActionButtonStyle}" Background="#566070" BorderBrush="#566070" />
                        </StackPanel>
                        <TextBlock Text="入力" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding Message}" Foreground="#A43F3F" Margin="0,0,0,8" TextWrapping="Wrap" />

                    <WrapPanel>
                        <StackPanel Width="160">
                            <TextBlock Text="コード / ティッカー / 会社名" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Ticker, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="銘柄名 / 会社名（検索可）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="国" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="130">
                            <TextBlock Text="通貨 例: USD / JPY" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="証券会社" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Broker, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="購入株数" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding PurchaseShares, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="購入単価（未確定なら0）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding PurchaseUnitPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="170">
                            <TextBlock Text="購入時為替レート" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding PurchaseExchangeRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="170">
                            <TextBlock Text="現在保有株数（未入力なら購入株数）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding CurrentShares, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="現在株価（未確定なら0）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding CurrentPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="170">
                            <TextBlock Text="現在為替レート" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding CurrentExchangeRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="190">
                            <TextBlock Text="1株あたり年間配当（年間合計）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding AnnualDividendPerShare, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="配当状態" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox SelectedValue="{Binding DividendStatus, Mode=TwoWay}" SelectedValuePath="Content" Height="30" Margin="0,0,14,10">
                                <ComboBoxItem Content="配当あり" />
                                <ComboBoxItem Content="配当なし" />
                                <ComboBoxItem Content="配当未入力" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="配当頻度（表示・予定管理用）" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding DividendFrequency, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Width="420">
                            <TextBlock Text="メモ" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Text="{Binding ShareChangeRatio, StringFormat=参考：株数変化倍率 {0} 倍}"
                               Foreground="#2F5B8C" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0" />
                    <TextBlock Text="年間配当見込みは、1株あたり年間配当（年間合計） × 現在保有株数 で計算します。配当頻度は将来の配当予定表示やカレンダー用の補助情報として扱います。"
                               TextWrapping="Wrap" Foreground="#566070" FontSize="12" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Text="計算プレビュー" Style="{StaticResource SectionTitleStyle}" />
            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="購入総額（入力通貨）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding PurchaseTotalUsd}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="購入総額JPY" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding PurchaseTotalJpy}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="実質取得単価" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding EffectiveAcquisitionPrice}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在評価額（入力通貨）" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentMarketValueUsd}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在評価額JPY" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentMarketValueJpy}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="通貨ベース含み益" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding UnrealizedGainUsd}" FontSize="20" FontWeight="SemiBold" Foreground="#1C7C54" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="円ベース含み益" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding UnrealizedGainJpy}" FontSize="20" FontWeight="SemiBold" Foreground="#1C7C54" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="通貨ベース含み益率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding UnrealizedGainRateUsd}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="円ベース含み益率" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding UnrealizedGainRateJpy}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間配当見込み" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualDividendForecast}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="年間配当見込みJPY" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AnnualDividendForecastJpy}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月平均配当見込み" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MonthlyDividendForecast}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="月平均配当見込みJPY" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MonthlyDividendForecastJpy}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="取得額ベース利回り" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding YieldOnCost}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在株価ベース利回り" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentDividendYield}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
