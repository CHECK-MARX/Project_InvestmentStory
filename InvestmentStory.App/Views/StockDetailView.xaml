<UserControl x:Class="InvestmentStory.App.Views.StockDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding HeaderTicker}" Foreground="{DynamicResource AccentBlueBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding HeaderName}" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="{Binding HeaderBroker}" Style="{StaticResource SubtleTextStyle}" />
                    <TextBlock Text="{Binding DetailScope}" Style="{StaticResource SubtleTextStyle}" />
                    <TextBlock Text="{Binding PositionBreakdown}" Style="{StaticResource SubtleTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding CurrentPriceLabel}" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding CurrentPrice}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="評価額" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding CurrentMarketValueJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="含み損益" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding UnrealizedGainJpy}" FontSize="22" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPositiveGain}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource ProfitBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasNegativeGain}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource LossBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding UnrealizedGainRateJpy}" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{Binding HeaderIncomeLabel}" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding HeaderIncomeValue}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                    <TextBlock Text="{Binding HeaderIncomeSubValue}" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource MetricCardStyle}">
            <TabControl>
                <TabItem Header="概要">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="4" Visibility="{Binding MutualFundDetailVisibility}">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="保有口数" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundUnitsHeld}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="取得単価" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundAverageCostNav}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="基準価額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundCurrentNav}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="評価損益率" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundUnrealizedGainLossRate}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="取得金額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundAcquisitionAmount}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="評価額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundMarketValue}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="評価損益" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundUnrealizedGainLoss}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="分配金受取方法" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundDistributionMethod}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="基準価額更新日" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundNavDate}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="基準価額取得元" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundNavSource}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="累計売却額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundTotalSaleAmount}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="トータルリターン" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding FundTotalReturn}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="4" Visibility="{Binding StockDetailVisibility}">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="購入総額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding PurchaseTotalJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="実質取得単価" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding EffectiveAcquisitionPrice}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="現在利回り" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentDividendYield}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="何倍になったか" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding Multiple}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="投資ストーリー" Style="{StaticResource SectionTitleStyle}" Margin="0,8,0,12" />
                            <Border Style="{StaticResource MetricCardStyle}" Margin="0">
                                <TextBlock Text="{Binding Story}" TextWrapping="Wrap" FontSize="15" LineHeight="25" Foreground="{DynamicResource PrimaryTextBrush}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="価格・損益">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="外貨ベース評価額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentMarketValueUsd}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="外貨ベース含み損益" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding UnrealizedGainUsd}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="為替影響額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrencyImpactJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource MetricCardStyle}" Height="220">
                                <TextBlock Text="株価推移グラフは、履歴データ取得機能の追加後にここへ表示します。"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="配当">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="3" Margin="4,16,4,4">
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="年間配当" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding AnnualDividend}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="月平均配当" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding MonthlyDividendJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="取得額ベース利回り" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding YieldOnCost}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="取引履歴">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="6">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="累計買付額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding TotalBuyAmountJpy}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="累計売却額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding TotalSaleAmountJpy}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="現在数量" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentTradeQuantity}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="平均取得単価" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding AverageTradeCost}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="実現損益" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding RealizedGainLossJpy}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="取引件数" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding TradeCount}" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="{Binding TradeDataWarning}"
                                       Foreground="{DynamicResource WarningBrush}"
                                       TextWrapping="Wrap"
                                       Margin="4,8,4,10" />
                            <DataGrid ItemsSource="{Binding TradeRows}" Height="360">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="約定日" Binding="{Binding TradeDate}" Width="100" />
                                    <DataGridTextColumn Header="受渡日" Binding="{Binding SettlementDate}" Width="100" />
                                    <DataGridTextColumn Header="証券会社" Binding="{Binding Broker}" Width="110" />
                                    <DataGridTextColumn Header="口座区分" Binding="{Binding AccountType}" Width="130" />
                                    <DataGridTextColumn Header="取引種別" Binding="{Binding TradeType}" Width="100" />
                                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="90" />
                                    <DataGridTextColumn Header="単価" Binding="{Binding UnitPrice}" Width="120" />
                                    <DataGridTextColumn Header="通貨" Binding="{Binding Currency}" Width="70" />
                                    <DataGridTextColumn Header="為替" Binding="{Binding ExchangeRate}" Width="80" />
                                    <DataGridTextColumn Header="円換算額" Binding="{Binding SettlementAmountJpy}" Width="130" />
                                    <DataGridTextColumn Header="手数料" Binding="{Binding FeeJpy}" Width="110" />
                                    <DataGridTextColumn Header="税金" Binding="{Binding TaxJpy}" Width="110" />
                                    <DataGridTextColumn Header="実現損益" Binding="{Binding RealizedGainLossJpy}" Width="130" />
                                    <DataGridTextColumn Header="取引後数量" Binding="{Binding AfterTradeQuantity}" Width="110" />
                                    <DataGridTextColumn Header="取引後平均" Binding="{Binding AfterTradeAverageCost}" Width="130" />
                                    <DataGridTextColumn Header="データ元" Binding="{Binding Source}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="データ情報">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="株価取得元" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentPriceSource}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CurrentPriceAcquiredAt}" Style="{StaticResource SubtleTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="配当情報取得元" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding DividendInfoSource}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DividendInfoAcquiredAt}" Style="{StaticResource SubtleTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="項目別データ品質" Style="{StaticResource SectionTitleStyle}" Margin="4,12,4,8" />
                            <DataGrid ItemsSource="{Binding DataQualityRows}" Height="360">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="項目" Binding="{Binding FieldName}" Width="160" />
                                    <DataGridTextColumn Header="値" Binding="{Binding Value}" Width="150" />
                                    <DataGridTextColumn Header="取得元種別" Binding="{Binding SourceType}" Width="130" />
                                    <DataGridTextColumn Header="取得元" Binding="{Binding SourceName}" Width="180" />
                                    <DataGridTextColumn Header="取得日時" Binding="{Binding RetrievedAt}" Width="150" />
                                    <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="120" />
                                    <DataGridTextColumn Header="メモ" Binding="{Binding Memo}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
