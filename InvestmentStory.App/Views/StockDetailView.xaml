<UserControl x:Class="InvestmentStory.App.Views.StockDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding HeaderTicker}" Foreground="{DynamicResource AccentBlueBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding HeaderName}" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="{Binding HeaderBroker}" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="現在株価" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding CurrentPrice}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="評価額" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding CurrentMarketValueJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="含み損益" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding UnrealizedGainJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                    <TextBlock Text="{Binding UnrealizedGainRateJpy}" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="年間配当" Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Text="{Binding AnnualDividendJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                    <TextBlock Text="{Binding YieldOnCost}" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource MetricCardStyle}">
            <TabControl>
                <TabItem Header="概要">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="購入総額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding PurchaseTotalJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="実質取得単価" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding EffectiveAcquisitionPrice}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="現在利回り" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentDividendYield}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="何倍になったか" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding Multiple}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="投資ストーリー" Style="{StaticResource SectionTitleStyle}" Margin="0,8,0,12" />
                            <Border Style="{StaticResource MetricCardStyle}" Margin="0">
                                <TextBlock Text="{Binding Story}" TextWrapping="Wrap" FontSize="15" LineHeight="25" Foreground="{DynamicResource PrimaryTextBrush}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="価格・損益">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="外貨ベース評価額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentMarketValueUsd}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="外貨ベース含み損益" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding UnrealizedGainUsd}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ProfitBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="為替影響額" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrencyImpactJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource MetricCardStyle}" Height="220">
                                <TextBlock Text="株価推移グラフは、履歴データ取得機能の追加後にここへ表示します。"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="配当">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="3" Margin="4,16,4,4">
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="年間配当" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding AnnualDividend}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="月平均配当" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding MonthlyDividendJpy}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="取得額ベース利回り" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding YieldOnCost}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource DividendBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="取引履歴">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="4,16,4,4">
                        <TextBlock Text="買付、売却、入庫、分割、平均取得単価の変化、実現損益は次の段階で取引履歴ViewModelと接続します。"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </TabItem>

                <TabItem Header="データ情報">
                    <UniformGrid Columns="2" Margin="4,16,4,4">
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="株価取得元" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="{Binding CurrentPriceSource}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentPriceAcquiredAt}" Style="{StaticResource SubtleTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="配当情報取得元" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="{Binding DividendInfoSource}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DividendInfoAcquiredAt}" Style="{StaticResource SubtleTextStyle}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
