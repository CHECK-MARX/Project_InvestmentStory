<UserControl x:Class="InvestmentStory.App.Views.BrokerIntegrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="データ取込・統合設定" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="この画面では、CSV取込データを既存の手入力データへどう反映するかを管理します。証券会社ログイン自動取得は未対応です。CSVで取れた口座データを正として扱い、発注機能は実装しません。"
                       TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14" Margin="0,0,0,16" />

            <UniformGrid Columns="2">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="現在の取込方式" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentMode}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="安全方針" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="CSVデータ優先 / 読み取り専用 / 発注なし" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,8,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="CSV取込へ" Command="{Binding OpenCsvImportCommand}" Style="{StaticResource ActionButtonStyle}" />
                            <Button Content="方針を保存" Command="{Binding SaveModeCommand}" Style="{StaticResource ActionButtonStyle}" />
                        </StackPanel>
                        <TextBlock Text="取込・マージ方針" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding Message}" Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,8" />

                    <WrapPanel>
                        <StackPanel Width="260">
                            <TextBlock Text="取込方式" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding BrokerDataModes}"
                                      SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                                      Height="32" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="360">
                            <TextBlock Text="既存手入力データの扱い" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding MergePolicies}"
                                      SelectedItem="{Binding SelectedMergePolicy, Mode=TwoWay}"
                                      Height="32" Margin="0,0,14,10" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="取り込み時のルール" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="15" Margin="0,0,0,8" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="対応状況" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding SupportedConnectors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="15" Margin="0,0,0,8" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="登録済みデータとの突き合わせ" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding ExistingSummary}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding ExistingRows}" AutoGenerateColumns="False" MinHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ティッカー" Binding="{Binding Ticker}" Width="90" />
                            <DataGridTextColumn Header="銘柄名" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="証券会社" Binding="{Binding Broker}" Width="140" />
                            <DataGridTextColumn Header="通貨" Binding="{Binding Currency}" Width="70" />
                            <DataGridTextColumn Header="現在株数" Binding="{Binding CurrentShares}" Width="100" />
                            <DataGridTextColumn Header="登録元" Binding="{Binding Source}" Width="140" />
                            <DataGridTextColumn Header="保護する項目" Binding="{Binding ProtectedFields}" Width="190" />
                            <DataGridTextColumn Header="取込時の扱い" Binding="{Binding PlannedAction}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
