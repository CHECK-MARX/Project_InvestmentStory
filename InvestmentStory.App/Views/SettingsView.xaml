<UserControl x:Class="InvestmentStory.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="設定" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="公開APIとCSV取込を優先します。注文機能、二要素認証やCAPTCHAの自動回避、ログイン情報の無断保存は行いません。"
                       TextWrapping="Wrap" Foreground="#566070" FontSize="14" Margin="0,0,0,16" />

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" />
                        <TextBlock Text="データ取得設定" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>
                    <TextBlock Text="{Binding Message}" Foreground="#A43F3F" Margin="0,0,0,8" />
                    <WrapPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="市場データ取得モード" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding MarketDataModes}" SelectedItem="{Binding MarketDataMode}" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="米国株APIプロバイダー" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding UsProviders}" SelectedItem="{Binding UsMarketDataProvider}" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="日本株APIプロバイダー" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding JapanProviders}" SelectedItem="{Binding JapanMarketDataProvider}" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="220">
                            <TextBlock Text="為替APIプロバイダー" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding ExchangeProviders}" SelectedItem="{Binding ExchangeRateProvider}" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="260">
                            <TextBlock Text="証券会社データ取得方式" Style="{StaticResource LabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding BrokerDataModes}" SelectedItem="{Binding BrokerDataMode}" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="260">
                            <TextBlock Text="Alpha Vantage API Key" Style="{StaticResource LabelTextStyle}" />
                            <PasswordBox x:Name="AlphaVantagePasswordBox" PasswordChanged="AlphaVantagePasswordBox_OnPasswordChanged" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="260">
                            <TextBlock Text="J-Quants API Key / Token" Style="{StaticResource LabelTextStyle}" />
                            <PasswordBox x:Name="JQuantsPasswordBox" PasswordChanged="JQuantsPasswordBox_OnPasswordChanged" Height="30" Margin="0,0,14,10" />
                        </StackPanel>
                        <StackPanel Width="180">
                            <TextBlock Text="APIタイムアウト秒数" Style="{StaticResource LabelTextStyle}" />
                            <TextBox Text="{Binding ApiTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel Margin="0,4,0,0">
                        <CheckBox Content="API取得失敗時に最後の取得値を使う" IsChecked="{Binding UseLastValueOnApiFailure}" Margin="0,0,24,8" />
                        <CheckBox Content="ログイン情報を保存する" IsChecked="{Binding SaveLoginCredentials}" Margin="0,0,24,8" />
                        <CheckBox Content="APIレスポンスログを有効にする" IsChecked="{Binding EnableApiResponseLog}" Margin="0,0,24,8" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="ログ再読込" Command="{Binding ReloadLogsCommand}" Style="{StaticResource ActionButtonStyle}" />
                        <TextBlock Text="API取得ログ" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding ApiLogs}" Height="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="取得日時" Binding="{Binding FetchedAt}" Width="150" />
                            <DataGridTextColumn Header="API種別" Binding="{Binding ApiType}" Width="140" />
                            <DataGridTextColumn Header="プロバイダー" Binding="{Binding Provider}" Width="140" />
                            <DataGridTextColumn Header="コード" Binding="{Binding Symbol}" Width="100" />
                            <DataGridTextColumn Header="HTTP" Binding="{Binding HttpStatusCode}" Width="70" />
                            <DataGridTextColumn Header="結果" Binding="{Binding Result}" Width="80" />
                            <DataGridTextColumn Header="エラー" Binding="{Binding ErrorMessage}" Width="260" />
                            <DataGridTextColumn Header="主要項目" Binding="{Binding Summary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
