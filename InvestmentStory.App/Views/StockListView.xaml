<UserControl x:Class="InvestmentStory.App.Views.StockListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="新規登録" Command="{Binding NewCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="編集" Command="{Binding EditCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="詳細" Command="{Binding DetailCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="削除" Command="{Binding DeleteCommand}" Style="{StaticResource ActionButtonStyle}" Background="#A43F3F" BorderBrush="#A43F3F" />
                <Button Content="選択銘柄のAPI更新" Command="{Binding RefreshSelectedCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="未取得銘柄だけAPI更新" Command="{Binding RefreshMissingCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Content="全保有銘柄のAPI更新" Command="{Binding RefreshAllCommand}" Style="{StaticResource ActionButtonStyle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <TextBlock Text="表示" Margin="0,0,8,0" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter, Mode=TwoWay}" Width="170" />
            </StackPanel>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Message}" Foreground="#A43F3F" Margin="0,0,0,8" TextWrapping="Wrap" />
            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="コード / ティッカー" Binding="{Binding Ticker}" Width="110" />
                <DataGridTextColumn Header="銘柄名" Binding="{Binding Name}" Width="160" />
                <DataGridTextColumn Header="国" Binding="{Binding Country}" Width="80" />
                <DataGridTextColumn Header="通貨" Binding="{Binding Currency}" Width="70" />
                <DataGridTextColumn Header="証券会社" Binding="{Binding Broker}" Width="120" />
                <DataGridTextColumn Header="現在保有株数" Binding="{Binding CurrentShares}" Width="110" />
                <DataGridTextColumn Header="実質取得単価" Binding="{Binding EffectiveAcquisitionPrice}" Width="140" />
                <DataGridTextColumn Header="現在株価" Binding="{Binding CurrentPrice}" Width="120" />
                <DataGridTextColumn Header="現在評価額（通貨）" Binding="{Binding CurrentMarketValue}" Width="150" />
                <DataGridTextColumn Header="現在評価額JPY" Binding="{Binding CurrentMarketValueJpy}" Width="130" />
                <DataGridTextColumn Header="通貨ベース含み益" Binding="{Binding UnrealizedGain}" Width="150" />
                <DataGridTextColumn Header="円ベース含み益" Binding="{Binding UnrealizedGainJpy}" Width="140" />
                <DataGridTextColumn Header="通貨ベース含み益率" Binding="{Binding UnrealizedGainRate}" Width="150" />
                <DataGridTextColumn Header="円ベース含み益率" Binding="{Binding UnrealizedGainRateJpy}" Width="130" />
                <DataGridTextColumn Header="年間配当見込み" Binding="{Binding AnnualDividendForecast}" Width="140" />
                <DataGridTextColumn Header="年間配当見込みJPY" Binding="{Binding AnnualDividendForecastJpy}" Width="160" />
                <DataGridTextColumn Header="取得額ベース利回り" Binding="{Binding YieldOnCost}" Width="150" />
                <DataGridTextColumn Header="現在株価ベース利回り" Binding="{Binding CurrentDividendYield}" Width="160" />
                <DataGridTextColumn Header="株価取得日時" Binding="{Binding PriceAcquiredAt}" Width="140" />
                <DataGridTextColumn Header="データ取得元" Binding="{Binding DataSource}" Width="160" />
            </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
