<UserControl x:Class="InvestmentStory.App.Views.StockListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:InvestmentStory.App.Infrastructure">
    <UserControl.Resources>
        <infra:BindingProxy x:Key="VmProxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,14">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="新規登録" Command="{Binding NewCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="編集" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="詳細" Command="{Binding DetailCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="削除" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="選択銘柄のAPI更新" Command="{Binding RefreshSelectedCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="未取得だけAPI更新" Command="{Binding RefreshMissingCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="全保有銘柄のAPI更新" Command="{Binding RefreshAllCommand}" Style="{StaticResource ActionButtonStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="表示" Style="{StaticResource LabelTextStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter, Mode=TwoWay}" Width="150" Margin="0,0,10,0" />
                    <TextBlock Text="単位" Style="{StaticResource LabelTextStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding GroupingModes}" SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" Width="130" Margin="0,0,10,0" />
                    <TextBlock Text="列" Style="{StaticResource LabelTextStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding DisplayModes}" SelectedItem="{Binding SelectedDisplayMode, Mode=TwoWay}" Width="120" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Message}"
                       Foreground="{DynamicResource WarningBrush}"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap" />
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      FrozenColumnCount="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="コード" Binding="{Binding Ticker}" Width="100" ElementStyle="{StaticResource DataGridCellTextStyle}" />
                    <DataGridTextColumn Header="銘柄名" Binding="{Binding Name}" Width="190" ElementStyle="{StaticResource DataGridCellTextStyle}" />

                    <DataGridTextColumn Header="種別" Binding="{Binding AssetTypeLabel}" Width="90"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="証券会社" Binding="{Binding Broker}" Width="120"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="口座区分" Binding="{Binding AccountType}" Width="110"
                                        ElementStyle="{StaticResource CenterCellTextStyle}"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="取得額" Binding="{Binding CostBasisJpy}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="評価額" Binding="{Binding MarketValueJpy}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="損益" Binding="{Binding GainLossJpy}" Width="130"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="損益率" Binding="{Binding GainLossRateJpy}" Width="110"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowBasicColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="種別" Binding="{Binding AssetTypeLabel}" Width="90"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="ファンド名" Binding="{Binding FundName}" Width="260"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="口座区分" Binding="{Binding FundAccountType}" Width="110"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="保有口数" Binding="{Binding FundUnitsHeld}" Width="120"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="取得単価" Binding="{Binding FundAverageCostNav}" Width="170"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="基準価額" Binding="{Binding FundCurrentNav}" Width="170"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="取得金額" Binding="{Binding FundAcquisitionAmount}" Width="140"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="評価額" Binding="{Binding FundMarketValue}" Width="140"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="評価損益" Binding="{Binding FundUnrealizedGainLoss}" Width="140"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="評価損益率" Binding="{Binding FundUnrealizedGainLossRate}" Width="120"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="基準価額更新日" Binding="{Binding FundNavDate}" Width="140"
                                        ElementStyle="{StaticResource CenterCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="データ取得元" Binding="{Binding FundNavSource}" Width="150"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="分配金受取" Binding="{Binding FundDistributionMethod}" Width="110"
                                        ElementStyle="{StaticResource CenterCellTextStyle}"
                                        Visibility="{Binding Data.ShowFundColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="証券会社" Binding="{Binding Broker}" Width="120"
                                        Visibility="{Binding Data.ShowStockColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="保有株数" Binding="{Binding CurrentShares}" Width="110"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowStockColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="現在株価" Binding="{Binding CurrentPrice}" Width="120"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowStockColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="現在評価額" Binding="{Binding CurrentMarketValue}" Width="140"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowStockColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="含み損益" Binding="{Binding UnrealizedGain}" Width="130"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowStockColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="国" Binding="{Binding Country}" Width="80"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="通貨" Binding="{Binding Currency}" Width="70"
                                        ElementStyle="{StaticResource CenterCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="実質取得単価" Binding="{Binding EffectiveAcquisitionPrice}" Width="140"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="評価額JPY" Binding="{Binding CurrentMarketValueJpy}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="通貨ベース含み益" Binding="{Binding UnrealizedGain}" Width="150"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="円ベース含み益" Binding="{Binding UnrealizedGainJpy}" Width="140"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="含み益率" Binding="{Binding UnrealizedGainRate}" Width="120"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="円ベース含み益率" Binding="{Binding UnrealizedGainRateJpy}" Width="140"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowProfitColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="年間配当" Binding="{Binding AnnualDividendForecast}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowDividendColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="年間配当円" Binding="{Binding AnnualDividendForecastJpy}" Width="140"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowDividendColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="取得額利回り" Binding="{Binding YieldOnCost}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowDividendColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="現在利回り" Binding="{Binding CurrentDividendYield}" Width="130"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowDividendColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="購入時為替" Binding="{Binding PurchaseExchangeRate}" Width="120"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowExchangeColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="現在為替" Binding="{Binding CurrentExchangeRate}" Width="120"
                                        ElementStyle="{StaticResource RightAlignedCellTextStyle}"
                                        Visibility="{Binding Data.ShowExchangeColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="円ベース含み益" Binding="{Binding UnrealizedGainJpy}" Width="140"
                                        ElementStyle="{StaticResource ProfitLossCellTextStyle}"
                                        Visibility="{Binding Data.ShowExchangeColumns, Source={StaticResource VmProxy}}" />

                    <DataGridTextColumn Header="株価更新日時" Binding="{Binding PriceAcquiredAt}" Width="140"
                                        ElementStyle="{StaticResource CenterCellTextStyle}"
                                        Visibility="{Binding Data.ShowDataColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="株価取得元" Binding="{Binding CurrentPriceSource}" Width="130"
                                        Visibility="{Binding Data.ShowDataColumns, Source={StaticResource VmProxy}}" />
                    <DataGridTextColumn Header="保有データ元" Binding="{Binding DataSource}" Width="160"
                                        Visibility="{Binding Data.ShowDataColumns, Source={StaticResource VmProxy}}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
