<UserControl x:Class="InvestmentStory.App.Views.CsvImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="ファイル選択" Command="{Binding BrowseCommand}" Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="プレビュー" Command="{Binding PreviewCommand}" Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="取込実行" Command="{Binding ImportCommand}" Style="{StaticResource ActionButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="CSV取込" Style="{StaticResource SectionTitleStyle}" />
                </DockPanel>
                <TextBlock Text="SBI証券、野村證券などのCSVを読み取り専用で自動判定します。対応済みCSVは、ファイル内の取込可能な保有・取引・配当情報をまとめて反映します。"
                           TextWrapping="Wrap" Foreground="#566070" FontSize="14" Margin="0,0,0,12" />
                <TextBlock Text="{Binding Message}" Foreground="#A43F3F" Margin="0,0,0,8" />
                <WrapPanel>
                    <StackPanel Width="180">
                        <TextBlock Text="証券会社（未判定CSV用）" Style="{StaticResource LabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding Brokers}" SelectedItem="{Binding Broker}" Height="30" Margin="0,0,14,10" />
                    </StackPanel>
                    <StackPanel Width="520">
                        <TextBlock Text="CSVファイル" Style="{StaticResource LabelTextStyle}" />
                        <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="プレビュー" Style="{StaticResource SectionTitleStyle}" />
                    <DataGrid ItemsSource="{Binding PreviewRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="60" />
                            <DataGridTextColumn Header="内容" Binding="{Binding Values}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="取込ログ" Style="{StaticResource SectionTitleStyle}" />
                    <ListBox ItemsSource="{Binding ImportLogs}" Height="420" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
